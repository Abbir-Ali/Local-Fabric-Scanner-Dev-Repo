    <div class="fb-dot" style="width:16px; height:16px; border-radius:50%; background:#EFDFD0; box-shadow:0 0 16px rgba(239,223,208,0.5); animation:fbDotBounce 0.9s ease-in-out infinite; animation-delay:0.18s;"></div>
    <div class="fb-dot" style="width:16px; height:16px; border-radius:50%; background:#EFDFD0; box-shadow:0 0 16px rgba(239,223,208,0.5); animation:fbDotBounce 0.9s ease-in-out infinite; animation-delay:0.36s;"></div>
