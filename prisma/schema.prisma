generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model ScanLog {
  id         Int      @id @default(autoincrement())
  shop       String
  orderId    String
  status     String
  scannedBy  String?
  timestamp  DateTime @default(now())
  details    String?
  staffEmail String?
}

model AppSettings {
  id                    Int     @id @default(autoincrement())
  shop                  String  @unique
  adminName             String  @default("Admin")
  adminPin              String  @default("1234")
  brandLogo             String?
  showStockTab          Boolean @default(true)
  showOrdersTab         Boolean @default(true)
  showHistoryTab        Boolean @default(true)
  enableScanButton      Boolean @default(true)
  enableInventorySearch Boolean @default(true)
  enableInventorySort   Boolean @default(true)
  showStaffManagement   Boolean @default(true)
  showLogoutButton      Boolean @default(true)
}

model Staff {
  id        Int      @id @default(autoincrement())
  shop      String
  name      String
  email     String
  pin       String
  createdAt DateTime @default(now())

  @@unique([shop, email])
}

model BinLocation {
  id        Int      @id @default(autoincrement())
  shop      String
  location  String
  createdAt DateTime @default(now())

  @@unique([shop, location])
  @@index([shop])
}